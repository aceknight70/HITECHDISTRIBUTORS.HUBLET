                    "Yes", // Floor Display (Yes/No)
                    "https://images.unsplash.com/photo-1593642532400-2682810df593?w=300", // Front Image
                    "", // Side Image
                    "", // Back Image
                    "", // Top Image
                    "", // Video
                    "Added via Spreadsheet Manager", // Staff Notes
                    "No" // Needs Verification
